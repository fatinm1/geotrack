# GeoTrack - Environment Variables
# Copy to .env and customize as needed.

# Database
DATABASE_URL=postgresql://geotrack:geotrack@localhost:5432/geotrack

# Redis
REDIS_URL=redis://localhost:6379/0

# OpenSky API (for real aircraft - recommended for higher rate limits)
# Get free at: https://opensky-network.org/
OPENSKY_USERNAME=
OPENSKY_PASSWORD=
OPENSKY_POLL_SECONDS=5

# MD CHART Traffic Cameras - real Maryland DOT feed (default if empty)
MDCHART_FEED_URL=https://chart.maryland.gov/DataFeeds/GetCamerasJson

# Detection settings
DETECTIONS_ENABLED=false
DETECTION_INTERVAL_SECONDS=20
USE_MOCK_DETECTOR=true

# Aircraft: false = OpenSky API (real), true = mock generator
USE_MOCK_OPENSKY=false
